# Copy this file to .env and edit values
# cp .env.example .env

# Database
POSTGRES_DB=ca_knowledge_base
POSTGRES_USER=ca_admin
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# App
NODE_ENV=production
PORT=3000

# Clerk (the "KGA Internal Portal" application / "KGA Staff" organization —
# see internal-kga-platform repo, NOT the client-facing Clerk instance behind
# platform.kgautam.in). This app has no login of its own; every request must
# arrive with a valid Clerk session token from portal.internal.kgautam.in in
# the Authorization header.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_ORGANIZATION_ID=
